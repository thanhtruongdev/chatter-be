generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model conversation_members {
  id              BigInt        @id @default(autoincrement())
  conversation_id BigInt
  user_id         BigInt
  role            member_role   @default(member)
  joined_at       DateTime      @default(now()) @db.Timestamptz(6)
  left_at         DateTime?     @db.Timestamptz(6)
  muted_until     DateTime?     @db.Timestamptz(6)
  is_pinned       Boolean       @default(false)
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime      @default(now()) @db.Timestamptz(6)
  deleted_at      DateTime?     @db.Timestamptz(6)
  conversations   conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_conversation_members_conversation")
  users           users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_conversation_members_user")

  @@unique([conversation_id, user_id], map: "uq_conversation_members_conversation_user")
  @@index([user_id, joined_at(sort: Desc), id(sort: Desc)], map: "idx_conversation_members_user_joined_at_desc")
}

/// This model contains an index with non-default null sort order and requires additional setup for migrations. Visit https://pris.ly/d/default-index-null-ordering for more info.
model conversations {
  id                                               BigInt                 @id @default(autoincrement())
  type                                             conversation_type
  title                                            String?                @db.VarChar(255)
  avatar_url                                       String?
  created_by                                       BigInt?
  last_message_id                                  BigInt?
  last_message_at                                  DateTime?              @db.Timestamptz(6)
  created_at                                       DateTime               @default(now()) @db.Timestamptz(6)
  updated_at                                       DateTime               @default(now()) @db.Timestamptz(6)
  deleted_at                                       DateTime?              @db.Timestamptz(6)
  conversation_members                             conversation_members[]
  users                                            users?                 @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_conversations_created_by")
  messages_conversations_last_message_idTomessages messages?              @relation("conversations_last_message_idTomessages", fields: [last_message_id], references: [id], onUpdate: NoAction, map: "fk_conversations_last_message")
  messages_messages_conversation_idToconversations messages[]             @relation("messages_conversation_idToconversations")

  @@index([last_message_at(sort: Desc), id(sort: Desc)], map: "idx_conversations_last_message_at_desc")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model message_attachments {
  id               BigInt   @id @default(autoincrement())
  message_id       BigInt
  url              String
  mime_type        String   @db.VarChar(255)
  size_bytes       BigInt
  file_name        String?
  width            Int?
  height           Int?
  duration_seconds Int?
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  messages         messages @relation(fields: [message_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_message_attachments_message")
}

model message_reactions {
  id         BigInt   @id @default(autoincrement())
  message_id BigInt
  user_id    BigInt
  emoji      String   @db.VarChar(32)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  messages   messages @relation(fields: [message_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_message_reactions_message")
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_message_reactions_user")

  @@unique([message_id, user_id, emoji], map: "uq_message_reactions_message_user_emoji")
}

model message_reads {
  id         BigInt   @id @default(autoincrement())
  message_id BigInt
  user_id    BigInt
  read_at    DateTime @default(now()) @db.Timestamptz(6)
  messages   messages @relation(fields: [message_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_message_reads_message")
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_message_reads_user")

  @@unique([message_id, user_id], map: "uq_message_reads_message_user")
  @@index([user_id, read_at(sort: Desc), id(sort: Desc)], map: "idx_message_reads_user_read_at_desc")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model messages {
  id                                                    BigInt                @id @default(autoincrement())
  conversation_id                                       BigInt
  sender_id                                             BigInt
  type                                                  message_type          @default(text)
  content                                               String?
  reply_to_message_id                                   BigInt?
  metadata                                              Json?
  edited_at                                             DateTime?             @db.Timestamptz(6)
  deleted_at                                            DateTime?             @db.Timestamptz(6)
  created_at                                            DateTime              @default(now()) @db.Timestamptz(6)
  updated_at                                            DateTime              @default(now()) @db.Timestamptz(6)
  conversations_conversations_last_message_idTomessages conversations[]       @relation("conversations_last_message_idTomessages")
  message_attachments                                   message_attachments[]
  message_reactions                                     message_reactions[]
  message_reads                                         message_reads[]
  conversations_messages_conversation_idToconversations conversations         @relation("messages_conversation_idToconversations", fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_messages_conversation")
  messages                                              messages?             @relation("messagesTomessages", fields: [reply_to_message_id], references: [id], onUpdate: NoAction, map: "fk_messages_reply_to")
  other_messages                                        messages[]            @relation("messagesTomessages")
  users                                                 users                 @relation(fields: [sender_id], references: [id], onUpdate: NoAction, map: "fk_messages_sender")

  @@index([conversation_id, created_at(sort: Desc), id(sort: Desc)], map: "idx_messages_conversation_created_at_desc")
  @@index([sender_id, created_at(sort: Desc), id(sort: Desc)], map: "idx_messages_sender_created_at_desc")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model user_blocks {
  id                                  BigInt   @id @default(autoincrement())
  blocker_id                          BigInt
  blocked_id                          BigInt
  created_at                          DateTime @default(now()) @db.Timestamptz(6)
  users_user_blocks_blocked_idTousers users    @relation("user_blocks_blocked_idTousers", fields: [blocked_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_blocks_blocked")
  users_user_blocks_blocker_idTousers users    @relation("user_blocks_blocker_idTousers", fields: [blocker_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_blocks_blocker")

  @@unique([blocker_id, blocked_id], map: "uq_user_blocks_blocker_blocked")
}

model user_devices {
  id           BigInt    @id @default(autoincrement())
  user_id      BigInt
  device_id    String    @db.VarChar(255)
  platform     String?   @db.VarChar(50)
  push_token   String?
  last_seen_at DateTime? @db.Timestamptz(6)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_devices_user")

  @@unique([user_id, device_id], map: "uq_user_devices_user_device")
}

model user_sessions {
  id                 BigInt    @id @default(autoincrement())
  user_id            BigInt
  refresh_token_hash String
  device_id          String?   @db.VarChar(255)
  ip_address         String?   @db.Inet
  user_agent         String?
  expires_at         DateTime  @db.Timestamptz(6)
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  revoked_at         DateTime? @db.Timestamptz(6)
  users              users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_sessions_user")

  @@index([user_id, expires_at], map: "idx_user_sessions_user_expires_at")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model users {
  id                                        BigInt                 @id @default(autoincrement())
  username                                  String                 @unique(map: "uq_users_username") @db.VarChar(50)
  email                                     String                 @unique(map: "uq_users_email") @db.VarChar(255)
  password_hash                             String
  display_name                              String?                @db.VarChar(100)
  avatar_url                                String?
  created_at                                DateTime               @default(now()) @db.Timestamptz(6)
  updated_at                                DateTime               @default(now()) @db.Timestamptz(6)
  deleted_at                                DateTime?              @db.Timestamptz(6)
  conversation_members                      conversation_members[]
  conversations                             conversations[]
  message_reactions                         message_reactions[]
  message_reads                             message_reads[]
  messages                                  messages[]
  user_blocks_user_blocks_blocked_idTousers user_blocks[]          @relation("user_blocks_blocked_idTousers")
  user_blocks_user_blocks_blocker_idTousers user_blocks[]          @relation("user_blocks_blocker_idTousers")
  user_devices                              user_devices[]
  user_sessions                             user_sessions[]
}

enum conversation_type {
  direct
  group
  channel
}

enum member_role {
  owner
  admin
  member
}

enum message_type {
  text
  image
  file
  system
}
